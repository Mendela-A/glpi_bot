BOT_TOKEN=                          # токен від @BotFather
TECHNICIANS_CHAT_ID=               # ID чату/групи техніків (від'ємне число для групи)
ADMIN_CHAT_ID=                     # ID чату для сповіщень про помилки (можна той самий)

# GLPI на хості — бот звертається через host.docker.internal
GLPI_URL=http://host.docker.internal:80
# Публічна (у межах локалки) адреса GLPI для посилань у повідомленнях
GLPI_EXTERNAL_URL=http://192.168.X.X:80

GLPI_APP_TOKEN=                    # Налаштування → Загальне → API → App-Token
GLPI_USER_TOKEN=                   # Профіль користувача GLPI → API token

REDIS_URL=redis://redis:6379/0

ALLOWED_GROUP_ID=                  # ID Telegram-групи для авторизації (опційно)
